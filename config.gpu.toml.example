# Afterglow GPU 디바이스 맵 오버라이드
#
# 이 파일을 `config.gpu.toml`로 복사하여 같은 디렉토리의 `config.toml` 옆에 두면
# 백엔드 기동 시 자동으로 딥 머지되어 적용됩니다.
#
# 복사: cp config.gpu.toml.example config.gpu.toml
#
# 머지 규칙: dict는 재귀 병합, 리스트/스칼라는 이 파일이 덮어쓴다.
# 즉, [[gpu.devices]] 엔트리를 여기에 두면 config.toml의 동일 키를 완전히 대체한다.

[gpu]
# GPU 디바이스 맵 커스터마이징
# vendor_id / device_id: lspci -nn 출력의 PCI ID (대문자 hex)
# is_audio: HDMI/DP 오디오 장치이면 true (GPU 카운트에서 제외됨)
# aliases: OpenStack flavor의 pci_passthrough:alias 이름 또는 flavor 이름에서 추출되는 짧은 이름 목록
#          예) gpu.3090_8c_16g → "3090", pci_passthrough:alias = "RTX3090:1" → "RTX3090"
#          GPU Spec Notion DB와 인스턴스를 매칭할 때 사용됩니다.
# 변경 후 백엔드를 재시작해야 적용됩니다.

# === Maxwell ===
[[gpu.devices]]
vendor_id = "10DE"
device_id = "17C2"
name = "GTX TITAN X"
is_audio = false
aliases = ["GTX_TITAN_X", "titan"]

[[gpu.devices]]
vendor_id = "10DE"
device_id = "0FB0"
name = "GM200 Audio"
is_audio = true

