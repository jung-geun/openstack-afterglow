# 통합 테스트용 크리덴셜 템플릿
#
# 이 파일을 복사해
#   backend/tests/integration/credentials.toml
# 로 저장하고 실제 값으로 채운다. (credentials.toml 은 .gitignore 에 추가됨)
#
# 우선순위: 환경변수 > credentials.toml > config.toml 의 [openstack]
#
# CI/CD 환경변수 규약:
#   AFTERGLOW_TEST_ADMIN_USERNAME / AFTERGLOW_TEST_ADMIN_PASSWORD / AFTERGLOW_TEST_ADMIN_PROJECT / AFTERGLOW_TEST_ADMIN_DOMAIN
#   AFTERGLOW_TEST_USER_USERNAME  / AFTERGLOW_TEST_USER_PASSWORD  / AFTERGLOW_TEST_USER_PROJECT  / AFTERGLOW_TEST_USER_DOMAIN

[admin]
# admin 프로젝트의 admin role 보유자 (is_system_admin=True 가 되어야 함)
# 미설정 시 config.toml 의 [openstack] 계정을 사용
username = "admin"
password = ""
project_name = "admin"
domain_name = "Default"

[user]
# 일반 사용자 — 특정 프로젝트의 member 또는 프로젝트 admin role만 보유 (is_system_admin=False)
# 이 계정이 없으면 admin/user 권한 분리 통합 테스트가 자동으로 skip 됨
# OpenStack에 수동으로 계정을 생성해야 함 (예: admin 프로젝트에 admin role 없는 test 사용자)
username = "test"
password = ""
project_name = "test-project"
domain_name = "Default"
