#cloud-config
# k3s 에이전트(worker) 노드 + OCCM — 클러스터: {{ cluster_name }}
{% if ssh_public_key %}
ssh_authorized_keys:
  - {{ ssh_public_key }}
{% endif %}

package_update: true
packages:
  - curl

write_files:
  - path: /opt/k3s/agent-join.sh
    permissions: "0750"
    content: |
      #!/bin/bash
      LOG="/var/log/k3s-agent.log"
      log() { echo "[k3s-agent] $(date '+%Y-%m-%d %H:%M:%S') $*" | tee -a "$LOG"; }

      # 이미 k3s-agent가 실행 중이면 종료 (멱등성)
      if systemctl is-active --quiet k3s-agent 2>/dev/null; then
        log "k3s-agent 이미 실행 중. 종료."
        exit 0
      fi

      log "서버 API({{ server_ip }}:6443) 대기 시작..."
      SERVER_READY=false
      for i in $(seq 1 360); do
        HTTP_CODE=$(curl -sk --connect-timeout 3 -o /dev/null -w '%{http_code}' https://{{ server_ip }}:6443/healthz 2>/dev/null || echo "000")
        if [ "$HTTP_CODE" != "000" ] && [ "$HTTP_CODE" != "" ]; then
          SERVER_READY=true
          log "서버 API 준비 완료 (${i}회 시도, HTTP ${HTTP_CODE})"
          break
        fi
        sleep 5
      done

      if [ "$SERVER_READY" != "true" ]; then
        log "ERROR: 서버 API에 30분 내 연결 실패. systemd가 2분 후 재시도 예정."
        exit 1
      fi

      log "k3s 에이전트 설치 시작 (버전: {{ k3s_version }}, OCCM 활성)..."
      curl -sfL https://get.k3s.io | \
        INSTALL_K3S_VERSION="{{ k3s_version }}" \
        K3S_URL="https://{{ server_ip }}:6443" \
        K3S_TOKEN="{{ node_token }}" \
        INSTALL_K3S_EXEC="--kubelet-arg=cloud-provider=external" \
        sh - 2>&1 | tee -a "$LOG"

      log "k3s-agent 서비스 활성화 대기 중..."
      for i in $(seq 1 60); do
        if systemctl is-active --quiet k3s-agent 2>/dev/null; then
          log "k3s-agent 서비스 정상 실행 중. 클러스터 join 완료."
          exit 0
        fi
        sleep 5
      done

      log "WARNING: k3s-agent 서비스가 5분 내 활성화되지 않음. 재시도 예정."
      systemctl status k3s-agent >> "$LOG" 2>&1 || true
      journalctl -u k3s-agent --no-pager -n 50 >> "$LOG" 2>&1 || true
      exit 1

  - path: /etc/systemd/system/k3s-agent-join.service
    permissions: "0644"
    content: |
      [Unit]
      Description=K3s Agent Join (OCCM) - {{ cluster_name }}
      After=network-online.target
      Wants=network-online.target
      ConditionPathExists=!/etc/systemd/system/k3s-agent.service

      [Service]
      Type=oneshot
      ExecStart=/opt/k3s/agent-join.sh
      Restart=on-failure
      RestartSec=120
      StartLimitIntervalSec=14400
      StartLimitBurst=20
      StandardOutput=journal
      StandardError=journal

      [Install]
      WantedBy=multi-user.target

runcmd:
  - systemctl daemon-reload
  - systemctl enable --now k3s-agent-join.service
