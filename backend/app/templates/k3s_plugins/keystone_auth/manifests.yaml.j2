---
# Keystone Auth — TLS Secret
apiVersion: v1
kind: Secret
metadata:
  name: keystone-auth-certs
  namespace: kube-system
type: kubernetes.io/tls
data:
  tls.crt: {{ cert_b64 }}
  tls.key: {{ key_b64 }}
---
# ConfigMap: 인증 정책 (비어있으면 인증만 활성화, 인가는 Kubernetes RBAC 사용)
apiVersion: v1
kind: ConfigMap
metadata:
  name: k8s-auth-policy
  namespace: kube-system
data:
  policies: |
{% if policy %}
{{ policy | indent(4, first=True) }}
{% else %}
    []
{% endif %}
---
# ServiceAccount
apiVersion: v1
kind: ServiceAccount
metadata:
  name: k8s-keystone-auth
  namespace: kube-system
---
# ClusterRoleBinding (ConfigMap 읽기 권한)
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRole
metadata:
  name: k8s-keystone-auth-role
rules:
  - apiGroups: [""]
    resources: ["configmaps"]
    verbs: ["get", "list", "watch"]
  - apiGroups: [""]
    resources: ["secrets"]
    verbs: ["get", "list", "watch"]
---
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRoleBinding
metadata:
  name: k8s-keystone-auth-binding
subjects:
  - kind: ServiceAccount
    name: k8s-keystone-auth
    namespace: kube-system
roleRef:
  kind: ClusterRole
  name: k8s-keystone-auth-role
  apiGroup: rbac.authorization.k8s.io
---
# Deployment
apiVersion: apps/v1
kind: Deployment
metadata:
  name: k8s-keystone-auth
  namespace: kube-system
spec:
  replicas: 1
  selector:
    matchLabels:
      app: k8s-keystone-auth
  template:
    metadata:
      labels:
        app: k8s-keystone-auth
    spec:
      serviceAccountName: k8s-keystone-auth
      tolerations:
        - key: node-role.kubernetes.io/control-plane
          effect: NoSchedule
      nodeSelector:
        node-role.kubernetes.io/control-plane: "true"
      containers:
        - name: k8s-keystone-auth
          image: {{ keystone_auth_image }}
          args:
            - /bin/k8s-keystone-auth
            - --tls-cert-file=/etc/pki/tls.crt
            - --tls-private-key-file=/etc/pki/tls.key
            - --keystone-url={{ os_auth_url }}
            - --policy-configmap-name=k8s-auth-policy
            - --listen=0.0.0.0:8443
          imagePullPolicy: IfNotPresent
          ports:
            - containerPort: 8443
              name: https
          volumeMounts:
            - name: certs
              mountPath: /etc/pki
              readOnly: true
      volumes:
        - name: certs
          secret:
            secretName: keystone-auth-certs
---
# Service
apiVersion: v1
kind: Service
metadata:
  name: k8s-keystone-auth
  namespace: kube-system
spec:
  selector:
    app: k8s-keystone-auth
  ports:
    - name: https
      port: 8443
      targetPort: 8443
  type: ClusterIP
