# OpenStack 인증
OS_AUTH_URL=http://keystone.example.com:5000/v3
OS_PROJECT_NAME=admin
OS_PROJECT_DOMAIN_NAME=Default
OS_USER_DOMAIN_NAME=Default
OS_REGION_NAME=RegionOne

# Manila 설정
OS_MANILA_SHARE_NETWORK_ID=
OS_MANILA_SHARE_TYPE=cephfstype

# Ceph 설정 (Manila CephFS 마운트용)
CEPH_MONITORS=192.168.1.10:6789,192.168.1.11:6789,192.168.1.12:6789

# 앱 설정
BACKEND_PORT=8000
FRONTEND_PORT=3000
SECRET_KEY=change-me-in-production
# 대시보드 새로고침 간격 (ms) — union.toml의 [app].refresh_interval_ms와 동일
REFRESH_INTERVAL_MS=5000

# Redis 캐시 (docker-compose 사용 시 redis://redis:6379/0)
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=30

# Nova 기본값
DEFAULT_NETWORK_ID=
DEFAULT_AVAILABILITY_ZONE=nova
BOOT_VOLUME_SIZE_GB=20
UPPER_VOLUME_SIZE_GB=50
