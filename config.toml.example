[services]
# 선택적 OpenStack 서비스 활성화 여부 (false면 라우터 미등록 + 사이드바 숨김)
magnum = false      # K8s 클러스터 (Heat 포함)
manila = false      # 공유 파일 시스템
zun = false         # 컨테이너

[gitlab_oidc]
# GitLab OIDC 로그인 활성화 여부
enabled = false
# GitLab 인스턴스 URL
gitlab_url = "https://git.dmslab.re.kr"
# GitLab OAuth2 Application Client ID / Secret
client_id = ""
client_secret = ""
# Keystone OS-FEDERATION에 등록된 Identity Provider ID / Protocol ID
idp_id = "gitlab"
protocol_id = "openid"
# OAuth2 콜백 URL (프론트엔드 주소 + /auth/gitlab/callback)
redirect_uri = "http://localhost:3000/auth/gitlab/callback"
# GitLab OAuth2 scope
scopes = "openid email profile read_user"
