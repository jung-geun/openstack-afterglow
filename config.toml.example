# Afterglow 통합 설정 파일
# 이 파일을 수정하면 백엔드와 프론트엔드 전체 설정이 변경됩니다.
# 우선순위: 환경변수 > config.toml > 기본값
#
# 오버라이드: 같은 디렉토리에 `config.<name>.toml` 을 두면 이 파일 위에 딥 머지된다.
#  - 예) config.gpu.toml  ← GPU 디바이스 맵 (config.gpu.toml.example 참고)
#  - 알파벳순으로 적용되어 뒤 파일이 앞을 이긴다. dict는 재귀 병합, 리스트는 덮어쓰기.

[openstack]
auth_url = "http://keystone.example.com:5000/v3"
project_name = "admin"
project_domain_name = "Default"
user_domain_name = "Default"
region_name = "RegionOne"
username = "admin"
password = "change-me-in-production"
# insecure = false                # 자체 서명 인증서 사용 시 true로 설정
# cacert = "/path/to/ca.pem"     # CA 인증서 경로 (insecure=false일 때 사용)

# Manila 설정
manila_endpoint = ""              # 서비스 카탈로그 대신 직접 지정할 경우
manila_share_network_id = ""
manila_share_type = "cephfs"
manila_nfs_share_type = "nfstype"  # NFS 프로토콜용 share type

# Ceph 모니터 (cloud-init CephFS 마운트용, 콤마 구분)
ceph_monitors = ""

[app]
backend_port = 8000
frontend_port = 3000
secret_key = "change-me-in-production"

# 사이트 표시 이름 및 설명 (로그인 화면 · 네비게이션 바)
site_name = "Afterglow"
site_description = "OpenStack VM + OverlayFS 배포 플랫폼"

# 로고 및 파비콘 경로 (frontend/static/ 기준, SvelteKit이 /로 서빙)
logo_path = "/logo.png"
favicon_path = "/favicon.ico"

# 프론트엔드 대시보드 자동 새로고침 간격 (밀리초)
# 권장 범위: 3000 ~ 30000
refresh_interval_ms = 5000

[cache]
redis_url = "redis://redis:6379/0"
# TTL 티어 (초). 리소스 변경 빈도에 따라 분류.
ttl_fast = 15       # 인스턴스, 볼륨, 플로팅IP 등 빈번히 변하는 리소스
ttl_normal = 30     # 네트워크, 라우터, 토폴로지, 대시보드
ttl_slow = 60       # 키페어, 보안그룹, 관리자 프로젝트/그룹/역할
ttl_static = 300    # 이미지, 플레이버, 토큰 검증

[session]
# 세션 유지 시간 (초). 이 시간이 지나면 재로그인 필요.
# Keystone 토큰 만료 시간보다 짧게 설정 권장 (Keystone 기본값: 3600초)
timeout_seconds = 3600
# 만료 N초 전에 경고 표시
warning_before_seconds = 300

[nova]
default_network_id = ""
default_availability_zone = "nova"
boot_volume_size_gb = 20
upper_volume_size_gb = 50

# [gpu] 섹션은 `config.gpu.toml` 로 분리되어 있습니다.
# → 샘플: config.gpu.toml.example
# → 사용: cp config.gpu.toml.example config.gpu.toml
# 같은 디렉토리에 두면 오버라이드 머지로 자동 적용됩니다.


[services]
# 선택적 OpenStack 서비스 활성화 여부 (false면 라우터 미등록 + 사이드바 숨김)
magnum = false      # K8s 클러스터 (Heat 포함)
manila = false      # 공유 파일 시스템
zun = false         # 컨테이너
k3s = false         # k3s 자체 관리 Kubernetes 클러스터

[k3s]
# k3s 자체 관리 Kubernetes 클러스터 설정 (services.k3s = true 시 활성화)
version = "v1.31.4+k3s1"
server_flavor_id = ""          # 서버(control plane) 노드 플레이버 ID
default_agent_flavor_id = ""   # 에이전트(worker) 노드 기본 플레이버 ID
server_image_id = ""           # Ubuntu 22.04+ 이미지 ID
callback_base_url = ""         # 서버 VM이 콜백할 백엔드 URL (예: http://10.0.0.1:8000)
kubeconfig_encryption_key = "" # AES-256-GCM 키 — openssl rand -hex 32 로 생성
boot_volume_size_gb = 30

[database]
# k3s 클러스터 영속화용 MariaDB/MySQL 연결 URL (선택적)
# 미설정 시 기존 Redis 방식으로 동작
# url = "mysql+asyncmy://afterglow:password@mariadb.example.com:3306/afterglow"
url = ""
# 커넥션 풀 설정
pool_size = 5
max_overflow = 10
# 앱 시작 시 테이블 자동 생성 (개발/테스트용, 운영에서는 false 후 migrations/ SQL 수동 실행 권장)
auto_create_tables = true

[cors]
# CORS 허용 origin (쉼표 구분). 프론트엔드 실제 접근 URL로 설정.
# 예: origins = "https://cloud.dmslab.re.kr"
origins = "http://localhost:3000,http://localhost"

[gitlab_oidc]
# GitLab OIDC 로그인 활성화 여부
enabled = false
# GitLab 인스턴스 URL
gitlab_url = "https://git.dmslab.re.kr"
# GitLab OAuth2 Application Client ID / Secret
client_id = ""
client_secret = ""
# Keystone OS-FEDERATION에 등록된 Identity Provider ID / Protocol ID
idp_id = "gitlab"
protocol_id = "openid"
# OAuth2 콜백 URL (프론트엔드 주소 + /auth/gitlab/callback)
redirect_uri = "http://localhost:3000/auth/gitlab/callback"
# GitLab OAuth2 scope
scopes = "openid email profile read_user"
